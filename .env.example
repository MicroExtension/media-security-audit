# Default: local-only access from the VM itself.
# For LAN access on a client VM, set MEDIA_AUDIT_BIND=0.0.0.0 and restrict access with the host firewall.
MEDIA_AUDIT_BIND=127.0.0.1
MEDIA_AUDIT_PORT=8080
MEDIA_AUDIT_UID=10001
MEDIA_AUDIT_GID=10001
MEDIA_AUDIT_REQUIRE_AUTH=true
MEDIA_AUDIT_WEB_USERNAME=admin
MEDIA_AUDIT_WEB_PASSWORD=
